# Required. Create in Discord Developer Portal -> Bot -> Reset/View Token.
DISCORD_BOT_TOKEN=

# Optional but recommended for invite-url/status clarity.
DISCORD_CLIENT_ID=

# Default allowlist: requested server/channel.
DISCORD_GUILD_ID=1500743272551813142
DISCORD_ALLOWED_CHANNEL_ID=1500743273361440823

# Keep the gateway loopback-only on the EC2 host.
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_GATEWAY_TOKEN_FILE=/home/ubuntu/.openclaw_gateway_token
OPENCLAW_MODEL=openclaw/clawbridge
OPENCLAW_TIMEOUT_SEC=120

# Slash commands do not need MESSAGE_CONTENT. Enable only if bot has the intent and you want @mention replies.
DISCORD_ENABLE_MENTION_RESPONSES=0

# 집현전-광부: Discord 링크 수집 → 집현전-클로 검토 큐.
# DISCORD_MINER_CHANNEL_ID defaults to DISCORD_ALLOWED_CHANNEL_ID when empty.
# Channel collection needs Discord MESSAGE_CONTENT intent; keep disabled unless the channel is dedicated to link intake.
DISCORD_MINER_CHANNEL_ID=
DISCORD_MINER_ENABLE_CHANNEL_COLLECTION=0
JIPHYEONJEON_MINER_INTAKE_PATH=/home/ubuntu/.openclaw/workspace/intake/jiphyeonjeon-miner/links.jsonl
JIPHYEONJEON_MINER_REVIEW_QUEUE_PATH=/home/ubuntu/.openclaw/workspace/review/jiphyeonjeon-claw/link-review-queue.jsonl

# Limit prompt/response size for Discord and gateway stability.
DISCORD_MAX_PROMPT_CHARS=4000
DISCORD_MAX_RESPONSE_CHARS=1800

# Markdown report used by /jiphyeonjeon_briefing and one-shot posting.
DISCORD_BRIEFING_SOURCE=/home/ubuntu/.openclaw/workspace/reports/daily-trends-latest.md

# Newsletter archive posting. Set this to Discord channel ID for
# 아카이브룸/뉴스레타-수집; do not reuse the main briefing channel unless intended.
DISCORD_NEWSLETTER_CHANNEL_ID=
DISCORD_NEWSLETTER_BRIEFING_SOURCE=/home/ubuntu/.openclaw/workspace/reports/newsletter-briefing-latest.md
