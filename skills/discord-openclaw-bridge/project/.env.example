# Required. Create in Discord Developer Portal -> Bot -> Reset/View Token.
DISCORD_BOT_TOKEN=

# Optional but recommended for invite-url/status clarity.
DISCORD_CLIENT_ID=

# Optional standalone 집현전-광부 bot. Use a separate Discord application/token
# when running discord-jiphyeonjeon-miner.service next to the OpenClaw bridge.
DISCORD_MINER_BOT_TOKEN=
DISCORD_MINER_CLIENT_ID=

# Optional standalone 집현전-여행자 bot. Use a separate Discord
# application/token when running discord-jiphyeonjeon-traveler.service so
# source-discovery requests appear under the Traveler agent identity, not Miner.
DISCORD_TRAVELER_BOT_TOKEN=
DISCORD_TRAVELER_CLIENT_ID=

# Optional standalone 집현전-경비원 bot. Posts the daily miner-seeds run summary
# to the 운영리포팅 forum. Without this token post_miner_seeds_report falls back
# to DISCORD_BOT_TOKEN, which means the post appears under the main bridge bot's
# identity. Provide a dedicated bot to keep ops reporting visually separated.
DISCORD_GUARD_BOT_TOKEN=
DISCORD_GUARD_CLIENT_ID=

# 운영리포팅 forum channel id. Default is the production "운영리포팅" forum.
DISCORD_OPS_REPORT_CHANNEL_ID=1502980129343672504

# Default allowlist: requested server/channel.
DISCORD_GUILD_ID=<DISCORD_GUILD_ID>
DISCORD_ALLOWED_CHANNEL_ID=<DISCORD_ALLOWED_CHANNEL_ID>

# Keep the gateway loopback-only on the EC2 host.
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_GATEWAY_TOKEN_FILE=/home/ubuntu/.openclaw_gateway_token
OPENCLAW_MODEL=openclaw/clawbridge
OPENCLAW_TIMEOUT_SEC=120

# Slash commands do not need MESSAGE_CONTENT. Enable only if bot has the intent and you want @mention replies.
DISCORD_ENABLE_MENTION_RESPONSES=0

# 집현전-광부: Discord 링크 수집 → 집현전-클로 검토 큐.
# DISCORD_MINER_CHANNEL_ID defaults to DISCORD_ALLOWED_CHANNEL_ID when empty.
# Channel collection needs Discord MESSAGE_CONTENT intent; keep disabled unless the channel is dedicated to link intake.
DISCORD_MINER_CHANNEL_ID=
DISCORD_MINER_ENABLE_CHANNEL_COLLECTION=0
JIPHYEONJEON_MINER_INTAKE_PATH=/home/ubuntu/.openclaw/workspace/intake/jiphyeonjeon-miner/links.jsonl
JIPHYEONJEON_MINER_REVIEW_QUEUE_PATH=/home/ubuntu/.openclaw/workspace/review/jiphyeonjeon-claw/link-review-queue.jsonl
JIPHYEONJEON_MINER_DECISIONS_PATH=/home/ubuntu/.openclaw/workspace/review/jiphyeonjeon-claw/link-review-decisions.jsonl
JIPHYEONJEON_MINER_APPROVED_EXPORT_PATH=/home/ubuntu/.openclaw/workspace/manual_links/approved-manual-links.jsonl

# 집현전-여행자: 심층 웹 리서치로 지속 가능한 출처 후보를 찾는 source-discovery agent.
# Uses the dedicated Traveler bot process for slash-command registration, but only
# records deep-research requests and source-candidate metadata; it does not approve sources.
DISCORD_TRAVELER_CHANNEL_ID=
JIPHYEONJEON_TRAVELER_RESEARCH_QUEUE_PATH=/home/ubuntu/.openclaw/workspace/review/jiphyeonjeon-traveler/research-requests.jsonl
JIPHYEONJEON_TRAVELER_SOURCE_QUEUE_PATH=/home/ubuntu/.openclaw/workspace/review/jiphyeonjeon-traveler/source-candidates.jsonl

# Limit prompt/response size for Discord and gateway stability.
DISCORD_MAX_PROMPT_CHARS=4000
DISCORD_MAX_RESPONSE_CHARS=1800

# Markdown report used by /jiphyeonjeon_briefing and one-shot posting.
DISCORD_BRIEFING_SOURCE=/home/ubuntu/.openclaw/workspace/reports/daily-trends-latest.md

# Newsletter archive posting. Set this to Discord channel ID for
# 아카이브룸/뉴스레타-수집; do not reuse the main briefing channel unless intended.
DISCORD_NEWSLETTER_CHANNEL_ID=
DISCORD_NEWSLETTER_BRIEFING_SOURCE=/home/ubuntu/.openclaw/workspace/reports/newsletter-briefing-latest.md
